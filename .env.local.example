# Supabase (create project at https://supabase.com)
# Use these in Vercel Environment Variables for automatic deploys
# Get anon key: Dashboard → Project Settings → API → "anon" "public" (long JWT starting with eyJ...)
NEXT_PUBLIC_SUPABASE_URL=https://yjnpklcujukqqogsqjqx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_mZPUlhFbhwIBf9KXrVT5Hg_s0Ce009T

# Optional: for build-time fetch from Supabase (same as above is enough for public read)
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Map (public map page + admin map picker). Required: use a PUBLIC token (starts with pk.eyJ...).
# Get it: https://account.mapbox.com → Access tokens → Default public token (or create one with Maps and Geocoding).
# Do NOT use the secret token (sk.) in the browser — it will not work for the map.
# NEXT_PUBLIC_MAPBOX_TOKEN=pk.eyJ1Ijoi...
